{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "nwidart/laravel-modules": "13.0.0",
        "spatie/laravel-activitylog": "5.0.0",
        "spatie/laravel-permission": "7.4.1",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\Appointments\\": "Modules/Appointments/app/",
            "Modules\\Auth\\": "Modules/Auth/app/",
            "Modules\\Billing\\": "Modules/Billing/app/",
            "Modules\\CMS\\": "Modules/CMS/app/",
            "Modules\\Core\\": "Modules/Core/app/",
            "Modules\\Doctors\\": "Modules/Doctors/app/",
            "Modules\\Laboratory\\": "Modules/Laboratory/app/",
            "Modules\\Notifications\\": "Modules/Notifications/app/",
            "Modules\\Patients\\": "Modules/Patients/app/",
            "Modules\\Pharmacy\\": "Modules/Pharmacy/app/",
            "Modules\\Reports\\": "Modules/Reports/app/",
            "Modules\\Settings\\": "Modules/Settings/app/",
            "Nwidart\\Modules\\": "vendor/nwidart/laravel-modules/src/",
            "Spatie\\Activitylog\\": "vendor/spatie/laravel-activitylog/src/",
            "Spatie\\LaravelPackageTools\\": "vendor/spatie/laravel-package-tools/src/",
            "Spatie\\Permission\\": "vendor/spatie/laravel-permission/src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "vendor/nwidart/laravel-modules/src/helpers.php",
            "vendor/spatie/laravel-activitylog/src/helpers.php",
            "vendor/spatie/laravel-permission/src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "repositories": [
        {
            "packagist.org": false
        },
        {
            "type": "path",
            "url": "C:/tmp/laravel-package-tools",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "C:/tmp/laravel-permission",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "C:/tmp/laravel-activitylog",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "C:/tmp/laravel-modules",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "C:/tmp/composer-merge-plugin",
            "options": {
                "symlink": false
            }
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
